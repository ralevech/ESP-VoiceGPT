# ====================================================================
# .gitignore для ESP32-Skeleton проекта
# Автор: ralevech
# ====================================================================

# PlatformIO
.pio/
.pioenvs/
.piolibdeps/
.clang_complete
.gcc-flags.json
project.generated
*.sublime-*

# VS Code
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
.vscode/*.code-workspace
.vscode/settings.json

# Скомпилированные файлы
*.bin
*.elf
*.o
*.a
*.d
*.pyc
__pycache__/
*.dump
*.core

# Временные файлы
*.swp
*.swo
*~
*.tmp
*.log

# Файлы сборки
/build/
/.cache/
/.temp/

# IDE файлы
/.idea/
*.iml
*.iws
*.ipr

# Файлы, создаваемые при загрузке
/uploadfs/
/spiffs_image/

# Файлы LittleFS data
/data/.*
/data/*.tmp

# Системные файлы
.DS_Store
Thumbs.db
desktop.ini

# Серийные порты и конфиги
/port_assignment.json
*.key
*.pem

# Файлы с секретами (приватные данные, не пушить в репозиторий)
/secrets.h
/secrets/